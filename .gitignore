# Environment
.env

# Python
__pycache__/
*.py[cod]
*$py.class
.Python
*.so
.venv/
venv/

# Node
node_modules/
frontend/node_modules/
frontend/dist/

# IDE
.idea/
.vscode/
*.swp
*.swo

# OS
.DS_Store
Thumbs.db

# Claude Code temp files
tmpclaude-*-cwd

# Build
backend/static/
*.egg-info/
dist/
build/

# Test coverage artifacts (enforced in CI, see docs/testing.md)
frontend/coverage/
backend/.coverage
backend/coverage.xml
backend/htmlcov/

# JUnit XML reports — emitted in CI for the flake-pr-comment workflow
# (bead xq19y) and locally when running pytest/vitest with --junitxml.
backend/junit.xml
frontend/junit.xml

# pytest-benchmark local result store (bd-skqln.10). CI uses --benchmark-storage
# under /tmp; this guard catches local runs that default to ./.benchmarks/.
backend/.benchmarks/
backend/tests/performance/.benchmarks/

# User guide screenshots (may contain PII)
docs/images/

# Playwright run-time artifacts (bd-lln2x). The visual-regression
# baseline PNGs under e2e/visual/__screenshots__/ ARE checked in (they
# are the test oracle); only ephemeral run output is excluded.
test-results/
test-results-visual/
playwright-report/
frontend/test-results/
